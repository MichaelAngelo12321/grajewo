{% extends 'panel/layout/base.html.twig' %}

{% block title %}Edycja strony statycznej{% endblock %}

{% block body %}
  <div class="page-body">
    <div class="container-fluid">
      <div class="card">
        <div class="card-header">
          <h1 class="col card-title fw-bold">Edycja strony statycznej</h1>

          <a href="{{ path('panel_static_page_list') }}" class="col-auto btn btn-outline-secondary">
            <i class="ti ti-arrow-back me-1"></i> Powrót do listy
          </a>
        </div>

        {{ form_start(form) }}
        <div class="card-body py-3">
          <div class="row">
            <div class="col-12">
              <div class="row">
                {{ form_row(form.title, {attr: { class: 'form-control form-control-lg'}}) }}

                {{ form_row(form.slug, {attr: { class: 'form-control'}}) }}

                {{ form_row(form.content, {attr: {class: 'form-control content-editor'}, row_attr: { class: 'mb-0' }}) }}
              </div>
            </div>
          </div>
        </div>

        <div class="card-footer text-end">
          <div class="d-flex">
            <button type="submit" class="btn btn-primary ms-auto">
              <i class="ti ti-check me-1"></i> Zapisz zmiany
            </button>
          </div>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('static_page_edit') }}"/>
        {{ form_end(form) }}
      </div>
    </div>
  </div>
{% endblock %}
