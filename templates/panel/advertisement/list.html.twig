{% extends 'panel/layout/base.html.twig' %}

{% block title %}Zarządzanie ogłoszeniami{% endblock %}

{% block body %}
  <div class="page-body">
    <div class="container-fluid">
      <div class="card">
        <div class="card-header">
          <h1 class="col card-title fw-bold">Zarządzanie ogłoszeniami</h1>
        </div>

        <div class="card-body border-bottom py-3">
          <form class="d-flex flex-column flex-md-row list-form" method="get">
            <input type="hidden" name="page" value="{{ app.request.get('page')|default(1) }}" />
          </form>
        </div>

        <div class="table-responsive">
          <table class="table card-table table-vcenter table-striped table-hover datatable">
            <thead>
            <tr>
              <th>ID</th>
              <th>Tytuł</th>
              <th>Autor</th>
              <th>Kontakt</th>
              <th>IP</th>
              <th>Wyświetleń</th>
              <th>Kliknięć</th>
              <th>Data dodania</th>
              <th>Promowane</th>
              <th>Status</th>
              <th></th>
            </tr>
            </thead>
            <tbody>
            {% for advertisement in advertisements %}
              <tr>
                <td>{{ advertisement.id }}</td>
                <td>
                    <div class="fw-bold">{{ advertisement.title }}</div>
                    <div class="text-muted small">{{ advertisement.content|u.truncate(50, '...') }}</div>
                </td>
                <td>{{ advertisement.author }}</td>
                <td>
                    {% if advertisement.email %}
                        <div><i class="ti ti-mail me-1"></i> {{ advertisement.email }}</div>
                    {% endif %}
                    {% if advertisement.phone %}
                        <div><i class="ti ti-phone me-1"></i> {{ advertisement.phone }}</div>
                    {% endif %}
                </td>
                <td>{{ advertisement.ipAddress|default('-') }}</td>
                <td>{{ advertisement.views|default(0) }}</td>
                <td>{{ advertisement.clicks|default(0) }}</td>
                <td>{{ advertisement.createdAt|date('d.m.Y H:i') }}</td>
                <td>
                  {% if advertisement.isPromoted %}
                    <span class="badge bg-yellow me-1"></span> Tak
                  {% else %}
                    <span class="badge bg-secondary me-1"></span> Nie
                  {% endif %}
                </td>
                <td>
                  {% if advertisement.isActive %}
                    <span class="badge bg-green me-1"></span> Aktywne
                  {% else %}
                    <span class="badge bg-red me-1"></span> Nieaktywne
                  {% endif %}
                </td>
                <td>
                  <div class="btn-list justify-content-end">
                    <a href="{{ path('panel_advertisement_toggle_active', {'advertisementId': advertisement.id}) }}" class="btn btn-icon {{ advertisement.isActive ? 'btn-green' : 'btn-outline-green' }}" title="{{ advertisement.isActive ? 'Dezaktywuj' : 'Aktywuj' }}">
                      <i class="ti ti-check"></i>
                    </a>
                    <a href="{{ path('panel_advertisement_toggle_promoted', {'advertisementId': advertisement.id}) }}" class="btn btn-icon {{ advertisement.isPromoted ? 'btn-yellow' : 'btn-outline-yellow' }}" title="{{ advertisement.isPromoted ? 'Wyłącz promowanie' : 'Włącz promowanie' }}">
                      <i class="ti ti-star"></i>
                    </a>
                    <a href="{{ path('panel_advertisement_edit', {'advertisementId': advertisement.id}) }}" class="btn btn-icon btn-primary" title="Edytuj">
                      <i class="ti ti-edit"></i>
                    </a>
                    <a href="{{ path('panel_advertisement_remove', {'advertisementId': advertisement.id}) }}" class="btn btn-danger btn-icon js-confirm">
                      <i class="ti ti-trash"></i>
                    </a>
                  </div>
                </td>
              </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="text-center py-4">Brak ogłoszeń</td>
                </tr>
            {% endfor %}
            </tbody>
          </table>
        </div>

        <div class="card-footer d-flex align-items-center">
          <p class="m-0 text-secondary">Pokazane <span>{{ paginator.currentPageFirstItem|default(0) }}</span> do <span>{{ paginator.currentPageLastItem|default(0) }}</span> z <span>{{ paginator.totalItems|default(0) }}</span> ogłoszeń</p>

          <div class="m-0 ms-auto">
            {{ paginator.toHtml|raw }}
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
