{% extends 'panel/layout/base.html.twig' %}

{% block title %}Lista artykułów{% endblock %}

{% block body %}
  <div class="page-body">
    <div class="container-fluid">
      <div class="card">
        <div class="card-header">
          <h3 class="col card-title">Artykuły</h3>

          <a href="#" class="col-auto btn btn-primary">
            <i class="ti ti-plus"></i> Dodaj artykuł
          </a>
        </div>

        <div class="card-body border-bottom py-3">
          <div class="d-flex flex-column flex-md-row">
            <div class="text-secondary">
              Pokaż
              <div class="mx-2 d-inline-block">
                <input type="text" class="form-control form-control-sm" value="15" size="3" aria-label="Invoices count">
              </div>
              artykułów z kategorii
              <div class="mx-2 d-inline-block">
                <label>
                  <select class="form-select form-select-sm">
                    <option value="" selected>Wszystkie</option>

                    {% for category in categories %}
                      {% if category.isRoot != true %}
                        <option value="{{ category.id }}">{{ category.name }}</option>
                      {% endif %}
                    {% endfor %}
                  </select>
                </label>
              </div>
            </div>

            <div class="mt-3 mt-md-0 ms-md-auto text-secondary">
              Szukaj:
              <div class="ms-2 d-inline-block">
                <input type="text" class="form-control form-control-sm" aria-label="Search invoice">
              </div>
            </div>
          </div>
        </div>

        <div class="table-responsive">
          <table class="table card-table table-vcenter table-striped table-hover datatable">
            <thead>
            <tr>
              <th class="w-1">
                <input class="form-check-input m-0 align-middle" type="checkbox"
                                     aria-label="Select all invoices">
              </th>
              <th class="w-1">ID</th>
              <th>Zdjęcie</th>
              <th>Tytuł</th>
              <th>Autor</th>
              <th>Dodano</th>
              <th>Status</th>
              <th></th>
            </tr>
            </thead>
            <tbody>
            {% for article in articles %}
              <tr>
                <td>
                  <label>
                    <input class="form-check-input m-0 align-middle" type="checkbox">
                  </label>
                </td>
                <td>{{ article.id }}</td>
                <td class="text-center">
                  <img
                    src="{{ article.imageUrl|default('/build/images/empty-photo.png')|imagine_filter('round_small') }}"
                    class="rounded-2"
                    width="40"
                  />
                </td>
                <td>{{ article.name }}</td>
                <td>{{ article.author.fullName }}</td>
                <td>{{ article.createdAt|date('d.m.Y H:i') }}</td>
                <td>
                  <span
                    class="badge bg-{{ article.status|article_status_color }} me-1"></span> {{ article.status|article_status_name }}
                </td>
                <td>
                  <div class="btn-list justify-content-end">
                    {% if article.status.value == 0 or article.status.value == 2 %}
                      <a
                        href="{{ path('panel_article_change_status', {'id': article.id, 'status': 1 }) }}"
                        class="btn btn-success btn-icon"
                        data-bs-toggle="tooltip"
                        data-bs-title="Opublikuj"
                      >
                        <i class="ti ti-eye"></i>
                      </a>
                    {% endif %}

                    {% if article.status.value == 1 %}
                      <a
                        href="{{ path('panel_article_change_status', {'id': article.id, 'status': 2 }) }}"
                        class="btn btn-icon opacity-45"
                        data-bs-toggle="tooltip"
                        data-bs-title="Wstrzymaj publikację"
                      >
                        <i class="ti ti-eye-exclamation"></i>
                      </a>
                    {% endif %}

                    <a href="" class="btn text-muted btn-icon">
                      <i class="ti ti-edit-circle"></i>
                    </a>

                    <a href="" class="btn btn-danger btn-icon" title="Usuń">
                      <i class="ti ti-trash"></i>
                    </a>
                  </div>
                </td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        </div>
        <div class="card-footer d-flex align-items-center">
          <p class="m-0 text-secondary">Pokazane <span>1</span> do <span>15</span> z <span>1643</span> artykułów</p>
          <ul class="pagination m-0 ms-auto">
            <li class="page-item disabled">
              <a class="page-link" href="#" tabindex="-1" aria-disabled="true">
                prev
              </a>
            </li>
            <li class="page-item"><a class="page-link" href="#">1</a></li>
            <li class="page-item active"><a class="page-link" href="#">2</a></li>
            <li class="page-item"><a class="page-link" href="#">3</a></li>
            <li class="page-item"><a class="page-link" href="#">4</a></li>
            <li class="page-item"><a class="page-link" href="#">5</a></li>
            <li class="page-item">
              <a class="page-link" href="#">
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
