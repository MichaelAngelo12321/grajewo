{% extends 'panel/layout/base.html.twig' %}

{% block title %}Lista artykułów{% endblock %}

{% block body %}
  <div class="page-body">
    <div class="container-fluid">
      <div class="card">
        <div class="card-header">
          <h1 class="col card-title fw-bold">Artykuły</h1>

          <a href="{{ path('panel_article_create') }}" class="col-auto btn btn-primary">
            <i class="ti ti-plus me-1"></i> Dodaj artykuł
          </a>
        </div>

        <div class="card-body border-bottom py-3">
          {% for type, messages in app.flashes %}
            {% for message in messages %}
              <div class="alert alert-{{ type }}">{{ message }}</div>
            {% endfor %}
          {% endfor %}

          <form class="d-flex flex-column flex-md-row list-form" method="get">
            <input type="hidden" name="page" value="{{ app.request.get('page')|default(1) }}" />

            <div class="text-secondary">
              Pokaż
              <div class="mx-2 d-inline-block">
                <input type="number" name="number" class="form-control form-control-sm" value="{{ app.request.get('number')|default('15') }}"  min="1" max="1000">
              </div>
              artykułów z kategorii
              <div class="mx-2 d-inline-block">
                <select name="category" class="form-select form-select-sm">
                  <option value="" {% if app.request.get('category') == null %}selected{% endif %}>Wszystkie</option>

                  {% for category in categories %}
                    {% if category.isRoot != true %}
                      <option value="{{ category.id }}" {% if app.request.get('category') == category.id %}selected{% endif %}>{{ category.name }}</option>
                    {% endif %}
                  {% endfor %}
                </select>
              </div>
            </div>

            <div class="mt-3 mt-md-0 ms-md-auto text-secondary">
              Szukaj:
              <div class="ms-2 d-inline-block">
                <input type="text" name="search_query" value="{{ app.request.get('search_query') }}" class="form-control form-control-sm">
              </div>
            </div>

            <div class="mt-3 mt-md-0">
              <div class="ms-2 d-inline-block">
                <button type="reset" class="btn btn-icon btn-sm btn-outline-muted reset-filter" data-bs-toggle="tooltip" data-bs-title="Resetuj filtry">
                  <i class="ti ti-eraser"></i>
                </button>
              </div>
            </div>
          </form>
        </div>

        <div class="table-responsive">
          <table class="table card-table table-vcenter table-striped table-hover datatable">
            <thead>
            <tr>
              <th class="w-1">ID</th>
              <th>Zdjęcie</th>
              <th>Tytuł</th>
              <th>Autor</th>
              <th>Dodano</th>
              <th>Status</th>
              <th></th>
            </tr>
            </thead>
            <tbody>
            {% for article in articles %}
              <tr>
                <td>{{ article.id }}</td>
                <td class="text-center">
                  <img
                    src="{{ article.imageUrl|default('/build/images/empty-photo.png')|imagine_filter('round_small') }}"
                    class="rounded-2"
                    width="40"
                  />
                </td>
                <td class="text-truncate">{{ article.name }}</td>
                <td>{{ article.author.fullName }}</td>
                <td>{{ article.createdAt|date('d.m.Y H:i') }}</td>
                <td>
                  <span
                    class="badge bg-{{ article.status|article_status_color }} me-1"></span> {{ article.status|article_status_name }}
                </td>
                <td>
                  <div class="btn-list justify-content-end">
                    {% if article.status.value == 0 or article.status.value == 2 %}
                      <a
                        href="{{ path('panel_article_change_status', {'id': article.id, 'status': 1 }) }}"
                        class="btn btn-success btn-icon"
                        data-bs-toggle="tooltip"
                        data-bs-title="Opublikuj"
                      >
                        <i class="ti ti-eye"></i>
                      </a>
                    {% endif %}

                    {% if article.status.value == 1 %}
                      <a
                        href="{{ path('panel_article_change_status', {'id': article.id, 'status': 2 }) }}"
                        class="btn btn-icon opacity-45"
                        data-bs-toggle="tooltip"
                        data-bs-title="Wstrzymaj publikację"
                      >
                        <i class="ti ti-eye-exclamation"></i>
                      </a>
                    {% endif %}

                    <a href="{{ path('panel_article_edit', {'id': article.id}) }}" class="btn text-muted btn-icon">
                      <i class="ti ti-edit-circle"></i>
                    </a>

                    <a href="{{ path('panel_article_delete', {'id': article.id}) }}" class="btn btn-danger btn-icon confirm">
                      <i class="ti ti-trash"></i>
                    </a>
                  </div>
                </td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        </div>
        <div class="card-footer d-flex align-items-center">
          <p class="m-0 text-secondary">Pokazane <span>{{ paginator.currentPageFirstItem }}</span> do <span>{{ paginator.currentPageLastItem }}</span> z <span>{{ paginator.totalItems }}</span> artykułów</p>

          <div class="m-0 ms-auto">
            {{ paginator.toHtml|raw }}
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
