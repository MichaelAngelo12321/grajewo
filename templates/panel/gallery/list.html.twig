{% extends 'panel/layout/base.html.twig' %}

{% block title %}Lista galerii zdjęć{% endblock %}

{% block body %}
  <div class="page-body">
    <div class="container-fluid">
      <div class="card">
        <div class="card-header">
          <h1 class="col card-title fw-bold">Galerie zdjęć</h1>

          <a href="{{ path('panel_gallery_create') }}" class="col-auto btn btn-primary">
            <i class="ti ti-plus me-1"></i> Dodaj galerię
          </a>
        </div>

        <div class="card-body border-bottom py-3">
          <form class="d-flex flex-column flex-md-row list-form" method="get">
            <input type="hidden" name="page" value="{{ app.request.get('page')|default(1) }}" />

            <div class="text-secondary">
              Pokaż
              <div class="mx-2 d-inline-block">
                <input type="number" name="number" class="form-control form-control-sm" value="{{ app.request.get('number')|default('15') }}"  min="1" max="1000">
              </div>
              galerii
            </div>
          </form>
        </div>

        <div class="table-responsive">
          <table class="table card-table table-vcenter table-striped table-hover datatable">
            <thead>
            <tr>
              <th class="w-1">ID</th>
              <th class="w-5">Pierwsze zdjęcie</th>
              <th class="w-5">Liczba zdjęć</th>
              <th>Tytuł</th>
              <th>Autor</th>
              <th>Dodano</th>
              <th>Zaktualizowano</th>
              <th></th>
            </tr>
            </thead>
            <tbody>
            {% for gallery in galleries %}
              <tr>
                <td>{{ gallery.id }}</td>
                <td class="text-center">
                  <img
                    src="{{ gallery.galleryImages[0].imageUrl|default('/build/images/empty-photo.png')|imagine_filter('round_small') }}"
                    class="rounded-2"
                    width="40"
                  />
                </td>
                <td>{{ gallery.galleryImages|length }}</td>
                <td class="fw-medium">{{ gallery.name }}</td>
                <td>{{ gallery.author.fullName }}</td>
                <td>{{ gallery.createdAt|date('d.m.Y H:i') }}</td>
                <td>{{ gallery.updatedAt|date('d.m.Y H:i') }}</td>
                <td>
                  <div class="btn-list justify-content-end">
                    <a href="{{ path('panel_gallery_edit', {'id': gallery.id}) }}" class="btn text-muted btn-icon">
                      <i class="ti ti-edit-circle"></i>
                    </a>

                    <a href="{{ path('panel_gallery_delete', {'id': gallery.id}) }}" class="btn btn-danger btn-icon js-confirm">
                      <i class="ti ti-trash"></i>
                    </a>
                  </div>
                </td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        </div>
        <div class="card-footer d-flex align-items-center">
          <p class="m-0 text-secondary">Pokazane <span>{{ paginator.currentPageFirstItem }}</span> do <span>{{ paginator.currentPageLastItem }}</span> z <span>{{ paginator.totalItems }}</span> galerii</p>

          <div class="m-0 ms-auto">
            {{ paginator.toHtml|raw }}
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
