{% extends 'panel/layout/base.html.twig' %}

{% block title %}Dodawanie reklamy{% endblock %}

{% block body %}
  <div class="page-body">
    <div class="container-fluid">
      <div class="card">
        <div class="card-header">
          <h1 class="col card-title fw-bold">Dodawanie nowej reklamy</h1>

          <a href="{{ path('panel_ad_list') }}" class="col-auto btn btn-outline-secondary">
            <i class="ti ti-arrow-back me-1"></i> Powrót do listy
          </a>
        </div>

        {{ form_start(form) }}
        <div class="card-body py-3">
          {{ form_row(form.title, {attr: { class: 'form-control form-control-lg'}}) }}

          {{ form_row(form.description, {attr: {class: 'form-control'}}) }}

          {{ form_row(form.targetUrl, {attr: { class: 'form-control'}}) }}

          {{ form_row(form.position, {attr: { class: 'form-select'}}) }}

          <fieldset class="form-fieldset">
            <label class="form-label required" for="ad-image-input">Plik reklamy</label>

            <div class="d-flex align-items-center justify-content-center mb-2">
              <img
                src=""
                id="ad-image-preview"
                class="rounded-2 d-none"
                height="150"
              />

              <button
                type="button"
                class="btn btn-outline-danger ms-auto d-none"
                id="ad-image-remove"
              >
                <i class="ti ti-trash me-1"></i> Usuń
              </button>
            </div>

            <input
              type="file"
              name="{{ field_name(form.imageUrl) }}"
              value="{{ field_value(form.imageUrl) }}"
              class="form-control"
              required
              accept="image/jpeg, image/png, image/gif"
              id="ad-image-input"
            />

            {% if field_errors(form.imageUrl) %}
              {{ form_errors(form.imageUrl) }}
            {% endif %}
          </fieldset>

          <hr />

          <div class="alert alert-warning mb-4">
            Pola <strong>Data rozpoczęcia</strong> i <strong>zakończenia publikacji</strong> są brane pod uwagę tylko w przypadku <strong>aktywnej</strong> reklamy
          </div>

          <div class="row mb-3">
            <div class="col-md-6 mb-3">
              {{ form_row(form.startDate, {attr: { class: 'form-control'}}) }}
            </div>

            <div class="col-md-6 mb-3">
              {{ form_row(form.endDate, {attr: { class: 'form-control'}}) }}
            </div>
          </div>

          {{ form_row(form.isActive, {attr: {class: 'form-check form-switch'}}) }}

          {{ form_errors(form) }}
        </div>

        <div class="card-footer text-end">
          <div class="d-flex">
            <button type="submit" class="btn btn-primary ms-auto">
              <i class="ti ti-check me-1"></i> Zapisz reklamę
            </button>
          </div>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('ad_add') }}"/>
        {{ form_end(form) }}
      </div>
    </div>
  </div>
{% endblock %}

{% block javascripts %}
  <script type="application/javascript">
    addEventListener('DOMContentLoaded', () => {
      // thumbnail preview
      const imageInput = document.getElementById('ad-image-input')
      const imagePreview = document.getElementById('ad-image-preview')
      const imageRemove = document.getElementById('ad-image-remove')

      imageInput.addEventListener('change', event => {
        if (event.target.files.length > 0) {
          imagePreview.src = URL.createObjectURL(
            event.target.files[0],
          )

          imagePreview.classList.remove('d-none')
          imageRemove.classList.remove('d-none')
          imagePreview.classList.add('d-block')
        }
      })

      // image remove
      imageRemove.addEventListener('click', () => {
        imageInput.value = ''
        imageInput.classList.remove('d-none')
        imagePreview.src = ''
        imagePreview.classList.remove('d-block')
        imagePreview.classList.add('d-none')
        imageRemove.classList.add('d-none')
      })
    })
  </script>
{% endblock %}
