<!doctype html>
<html lang="pl" data-bs-theme="light" data-bs-core="panel">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}{% endblock %} - Panel administracyjny {{ app_name }}</title>
  <link rel="shortcut icon" type="image/png" href="{{ asset('build/images/favicon.png') }}"/>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <meta name="turbo-cache-control" content="no-cache">
  <meta name="turbo-prefetch" content="false">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">

  {{ encore_entry_script_tags('panel') }}
  {{ encore_entry_script_tags('tabler') }}
  {{ encore_entry_link_tags('tabler') }}
  {{ encore_entry_link_tags('panel') }}

  {% block stylesheets %}
  {% endblock %}

  {% block javascripts %}
  {% endblock %}
</head>
<body>
<div class="page">
  <aside class="navbar navbar-vertical navbar-expand-lg">
    {% include 'panel/layout/_sidebar.html.twig' %}
    {% block sidebar %}{% endblock %}
  </aside>

  <div class="page-wrapper">
    {% block body %}{% endblock %}
  </div>

  <div class="toast-container top-0 end-0 p-3">
    {% for type, messages in app.flashes %}
    {% for message in messages %}
    <div class="toast text-bg-{{ type }}">
      <div class="d-flex">
        <div class="toast-body">
          {{ message }}
        </div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
      </div>
      {% endfor %}
      {% endfor %}
    </div>
  </div>
</div>
</body>
</html>
