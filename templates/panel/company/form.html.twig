{% extends 'panel/layout/base.html.twig' %}

{% block title %}{{ title|default('Firma') }}{% endblock %}

{% block body %}
  <div class="page-body">
    <div class="container-fluid">
      <div class="card">
        <div class="card-header">
          <h1 class="col card-title fw-bold">{{ title|default('Firma') }}</h1>

          <a href="{{ path('panel_company_list') }}" class="col-auto btn btn-outline-secondary">
            <i class="ti ti-arrow-back me-1"></i> Powrót do listy
          </a>
        </div>

        {{ form_start(form) }}
        <div class="card-body py-3">
          <div class="row">
            <div class="col-lg-8">
                <div class="row">
                  <div class="col-md-8">
                    {{ form_row(form.name) }}
                  </div>
                  <div class="col-md-4">
                    {{ form_row(form.category) }}
                  </div>
                </div>

                {{ form_row(form.description, {attr: {class: 'tinymce'}}) }}
                
                <div class="row">
                    <div class="col-md-6">
                        {{ form_row(form.address) }}
                    </div>
                    <div class="col-md-2">
                        {{ form_row(form.postalCode) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_row(form.city) }}
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
              <div class="mb-3">
                <label class="form-label">Logo firmy</label>
                {% if company is defined and company.logo %}
                    <div class="mb-2">
                        <img src="{{ asset(company.logo) }}" alt="Logo" class="img-fluid rounded" style="max-height: 150px;">
                    </div>
                {% endif %}
                {{ form_widget(form.logo) }}
                {{ form_errors(form.logo) }}
              </div>

              {{ form_row(form.slug) }}
              
              <div class="row">
                <div class="col-12">
                    {{ form_row(form.phone) }}
                </div>
                <div class="col-12">
                    {{ form_row(form.email) }}
                </div>
                <div class="col-12">
                    {{ form_row(form.website) }}
                </div>
              </div>

              <div class="mt-3">
                {{ form_row(form.isActive) }}
                {{ form_row(form.isPromoted) }}
              </div>
            </div>
          </div>
        </div>
        
        <div class="card-footer text-end">
            <button type="submit" class="btn btn-primary">Zapisz</button>
        </div>
        {{ form_end(form) }}
      </div>
    </div>
  </div>
{% endblock %}
