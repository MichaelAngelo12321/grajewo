{% extends 'app/layout/base.html.twig' %}

{% block title %}{{ app_meta_title }}{% endblock %}

{% block body %}
  {% import "app/home/partials/articles-list.html.twig" as articlesList %}

  {% include 'app/home/partials/top-category-articles.html.twig' %}

  {% include 'app/widgets/promo_space.html.twig' with {
    'slot': 'STRONA_GLOWNA_POD_KARUZELA'
  } %}

  {{ articlesList.horizontal('Najczęściej czytane', mostPopularArticles, 'info') }}

  {% if promotedCompanies|length > 0 %}
    <div class="card widget mb-5">
      <div class="card-header d-flex">
        <h5 class="section-title info"><a href="{{ path('company_list') }}">Polecane firmy</a></h5>
      </div>
      <div class="card-body">
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-6 g-3">
          {% for company in promotedCompanies %}
            <div class="col">
              <a href="{{ path('company_details', {slug: company.slug}) }}" class="d-block text-center text-decoration-none text-reset h-100 p-2 border rounded hover-shadow-sm transition-all">
                {% if company.logo %}
                  <img src="{{ company.logo|imagine_filter('company_logo_home') }}" class="img-fluid mb-2" alt="{{ company.name }}">
                {% else %}
                  <div class="d-flex align-items-center justify-content-center bg-light rounded mb-2" style="height: 100px;">
                    <i class="ti ti-building-store fs-1 text-muted"></i>
                  </div>
                {% endif %}
                <div class="fw-bold small text-truncate" title="{{ company.name }}">{{ company.name }}</div>
                <div class="text-muted smaller text-truncate">{{ company.city }}</div>
              </a>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

  {% if promotedAdvertisements|length > 0 %}
    <div class="card widget mb-5 border-warning" style="border-width: 2px;">
      <div class="card-header d-flex bg-warning-lt">
        <h5 class="section-title text-reset"><a href="{{ path('advertisement_list') }}" class="text-reset">Polecane ogłoszenia</a></h5>
        <div class="ms-auto">
          <a href="{{ path('advertisement_add') }}" class="btn btn-sm btn-dark">Dodaj ogłoszenie</a>
        </div>
      </div>
      <div class="card-body">
        <div class="row">
          {% for advertisement in promotedAdvertisements %}
            <div class="col-12 col-md-6 mb-3">
              <div class="d-flex justify-content-between align-items-start">
                <div class="fw-bold">{{ advertisement.title }}</div>
                <span class="badge bg-warning text-dark ms-2">Promowane</span>
              </div>
              <p class="mb-0">{{ advertisement.content }}</p>

              <div class="text-muted">
                <small>Dodane: {{ advertisement.createdAt|date|format_datetime(pattern=app_datetime_short_format) }}</small>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

  {% set visibleIndex = 0 %}
  {% for category in categories %}
    {% if not category.isRoot and category.positionOrder > 0 %}
      {% set visibleIndex = visibleIndex + 1 %}

      {% if visibleIndex == 1 %}
        <div class="row">
      {% endif %}

      {% if visibleIndex == 1 or visibleIndex == 2 %}
        <div class="col-12 col-lg-6">
          {{ articlesList.vertical(
            category,
            articles[category.id],
            category.color
          ) }}
        </div>
      {% endif %}

      {% if visibleIndex == 2 or (loop.last and visibleIndex == 1) %}
        </div>
      {% endif %}

      {% if visibleIndex == 4 %}
        {% include 'app/widgets/promo_space.html.twig' with {
          'slot': 'STRONA_GLOWNA_SRODEK_LISTY'
        } %}
      {% endif %}

      {% if visibleIndex > 2 %}
        {% if articles[category.id] %}
          {{ articlesList.horizontal(
            category,
            articles[category.id],
            category.color
          ) }}
        {% endif %}
      {% endif %}
    {% endif %}
  {% endfor %}
{% endblock %}
