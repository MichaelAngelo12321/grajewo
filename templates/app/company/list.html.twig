{% extends 'app/layout/base.html.twig' %}

{% block title %}
  Katalog Firm
  {% if currentCategory %} - {{ currentCategory.name }}
  {% endif %}
  - {{ app_name }}
{% endblock %}

{% block stylesheets %}
<style>
.company-carousel {
  display: flex;
  gap: 0.75rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding: 0.25rem 0.125rem;
}
.company-carousel::-webkit-scrollbar { display: none; }
.company-carousel-item {
  flex: 0 0 calc(33.333% - 0.5rem);
  scroll-snap-align: start;
  text-decoration: none;
  color: inherit;
}
@media (max-width: 767px) {
  .company-carousel-item { flex: 0 0 calc(80% - 0.375rem); }
}
.company-carousel-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
  width: 2rem;
  height: 2rem;
  border-radius: 50%;
  border: 1px solid var(--tblr-border-color);
  background: var(--tblr-bg-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 1.1rem;
  line-height: 1;
  padding: 0;
  box-shadow: 0 1px 3px rgba(0,0,0,.08);
  transition: box-shadow .15s;
}
.company-carousel-btn:hover { box-shadow: 0 2px 6px rgba(0,0,0,.15); }
.company-carousel-prev { left: -1rem; }
.company-carousel-next { right: -1rem; }
</style>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
  var carousel = document.getElementById('companyCarousel');
  if (!carousel) return;

  function scrollAmount() {
    var item = carousel.querySelector('.company-carousel-item');
    return item ? (item.offsetWidth + 12) * 3 : 300;
  }

  document.querySelector('.company-carousel-prev').addEventListener('click', function () {
    carousel.scrollBy({ left: -scrollAmount(), behavior: 'smooth' });
  });
  document.querySelector('.company-carousel-next').addEventListener('click', function () {
    carousel.scrollBy({ left: scrollAmount(), behavior: 'smooth' });
  });
});
</script>
{% endblock %}

{% block topContent %}
  <nav class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="{{ path('homepage') }}">Strona główna</a></li>
      {% if currentCategory == null %}
        <li class="breadcrumb-item active">Katalog Firm</li>
      {% else %}
        <li class="breadcrumb-item"><a href="{{ path('company_list') }}">Katalog Firm</a></li>
        <li class="breadcrumb-item active">{{ currentCategory.name }}</li>
      {% endif %}
    </ol>
  </nav>
{% endblock %}

{% block body %}
  {% include 'app/widgets/promo_space.html.twig' with {
    'slot': 'LEWA_1'
  } %}

  {% for type, messages in app.flashes() %}
    {% for message in messages %}
      <div class="alert alert-{{ type }} mb-3">{{ message }}</div>
    {% endfor %}
  {% endfor %}

  {# Header card: title + search + add button #}
  <div class="card mb-4 p-3">
    <div class="row align-items-center g-2">
      <div class="col-12 col-md">
        <h1 class="fs-5 fw-bold mb-0">Katalog Firm</h1>
        <p class="text-secondary mb-0 small">Znajdź firmę, której szukasz.</p>
      </div>
      <div class="col-12 col-md-auto ms-auto">
        <a href="{{ path('company_add') }}" class="btn btn-primary w-100">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
               stroke-width="2" stroke="currentColor" fill="none">
            <path d="M12 5v14M5 12h14"/>
          </svg>
          Dodaj firmę
        </a>
      </div>
    </div>
  </div>

  {# Promoted companies carousel #}
  {% if promotedCompanies|length > 0 %}
  <div class="card mb-4">
    <div class="card-header">
      <h3 class="card-title mb-0">Polecane firmy</h3>
    </div>
    <div class="card-body p-3">
      <div class="position-relative px-3">
        <button class="company-carousel-btn company-carousel-prev" type="button" aria-label="Poprzednie">&#8249;</button>
        <div class="company-carousel" id="companyCarousel">
          {% for company in promotedCompanies %}
            <a href="{{ path('company_details', {slug: company.slug}) }}"
               class="company-carousel-item card border-0 bg-light text-decoration-none text-body">
              <div class="card-body d-flex align-items-center gap-2 p-2">
                {% if company.logo %}
                  <img src="{{ asset(company.logo) }}" alt="{{ company.name }}"
                       class="rounded bg-white flex-shrink-0"
                       style="width: 48px; height: 48px; object-fit: contain;">
                {% else %}
                  <div class="bg-white rounded d-flex align-items-center justify-content-center text-muted flex-shrink-0"
                       style="width: 48px; height: 48px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                         stroke-width="1.5" stroke="currentColor" fill="none">
                      <path d="M3 21l18 0M9 8l1 0M9 12l1 0M9 16l1 0M14 8l1 0M14 12l1 0M14 16l1 0M5 21v-16a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/>
                    </svg>
                  </div>
                {% endif %}
                <div class="overflow-hidden">
                  <div class="fw-semibold text-truncate small">{{ company.name }}</div>
                  <div class="text-muted text-truncate" style="font-size: 0.7rem;">{{ company.city }}</div>
                </div>
              </div>
            </a>
          {% endfor %}
        </div>
        <button class="company-carousel-btn company-carousel-next" type="button" aria-label="Następne">&#8250;</button>
      </div>
    </div>
  </div>
  {% endif %}

  <div class="row">
    {# Category sidebar #}
    <div class="col-12 col-lg-4 col-xl-3 mb-3">
      <div class="list-group">
        <a href="{{ path('company_list') }}"
           class="list-group-item list-group-item-action d-flex align-items-center gap-2 {{ currentCategory is null ? 'active' }}">
          Wszystkie kategorie
        </a>
        {% for category in categories %}
          <a href="{{ path('company_list', {categorySlug: category.slug}) }}"
             class="list-group-item list-group-item-action {{ currentCategory and currentCategory.id == category.id ? 'active' }}">
            {{ category.name }}
          </a>
        {% endfor %}
      </div>
    </div>

    {# Company list #}
    <div class="col-12 col-lg-8 col-xl-9">
      {% for company in companies %}
        <div class="card mb-3 {{ company.isPromoted ? 'border-warning shadow-sm' : '' }}" {{ company.isPromoted ? 'style="border-width: 1px;"' : '' }}>
          <div class="card-body">
            <div class="row">
              <div class="col-md-auto mb-3 mb-md-0">
                {% if company.logo %}
                  <img src="{{ asset(company.logo) }}" alt="{{ company.name }}"
                       class="img-fluid rounded" style="max-width: 150px; max-height: 100px;">
                {% else %}
                  <div class="bg-light rounded d-flex align-items-center justify-content-center text-muted"
                       style="width: 150px; height: 100px;">Brak logo</div>
                {% endif %}
              </div>
              <div class="col">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <h3 class="fs-5 fw-bold mb-0">
                    <a href="{{ path('company_details', {slug: company.slug}) }}" class="text-decoration-none text-reset">
                      {{ company.name }}
                    </a>
                  </h3>
                  {% if company.isPromoted %}
                    <span class="badge bg-warning text-dark">Polecana</span>
                  {% endif %}
                </div>
                <p class="mb-2 text-muted small">{{ company.address }}, {{ company.postalCode }} {{ company.city }}</p>
                <p class="mb-3">{{ company.description|striptags|slice(0, 150) }}...</p>
                <div class="d-flex flex-wrap gap-3 text-muted small">
                  {% if company.phone %}
                    <div><span class="fw-bold">Tel:</span> {{ company.phone }}</div>
                  {% endif %}
                  {% if company.email %}
                    <div><span class="fw-bold">Email:</span> {{ company.email }}</div>
                  {% endif %}
                  {% if company.website %}
                    <div>
                      <span class="fw-bold">WWW:</span>
                      <a href="{{ company.website }}" target="_blank" rel="nofollow">
                        {{ company.website|replace({'https://': '', 'http://': ''})|slice(0, 20) }}...
                      </a>
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
            {% if is_granted('ROLE_ADMIN') %}
              <div class="d-flex justify-content-end align-items-center mt-3 pt-2 border-top">
                <a href="{{ path('panel_company_edit', {'id': company.id}) }}" class="btn btn-sm btn-outline-primary me-2">Edytuj</a>
                <a href="{{ path('panel_company_delete', {'id': company.id}) }}"
                   class="btn btn-sm btn-danger text-white js-confirm" data-method="post">Usuń</a>
              </div>
            {% endif %}
          </div>
        </div>
      {% else %}
        <div class="card p-5 text-center text-muted">
          <p class="mb-0">Brak firm w wybranej kategorii.</p>
        </div>
      {% endfor %}

      <div class="mt-4">{{ paginator.toHtml|raw }}</div>
    </div>
  </div>

  {% include 'app/widgets/promo_space.html.twig' with {
    'slot': 'LEWA_2'
  } %}
{% endblock %}
