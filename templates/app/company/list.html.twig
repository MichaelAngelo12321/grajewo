{% extends 'app/layout/base.html.twig' %}

{% block title %}
  Katalog Firm
  {% if currentCategory %} - {{ currentCategory.name }}
  {% endif %}
  - {{ app_name }}
{% endblock %}

{% block topContent %}
  <nav class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="{{ path('homepage') }}">Strona główna</a></li>

      {% if currentCategory == null %}
        <li class="breadcrumb-item active">Katalog Firm</li>
      {% else %}
        <li class="breadcrumb-item"><a href="{{ path('company_list') }}">Katalog Firm</a></li>
        <li class="breadcrumb-item active">{{ currentCategory.name }}</li>
      {% endif %}
    </ol>
  </nav>
{% endblock %}

{% block body %}
  {% for type, messages in app.flashes() %}
    {% for message in messages %}
      <div class="alert alert-{{ type }} mb-3">
        {{ message }}
      </div>
    {% endfor %}
  {% endfor %}

  <div class="card mb-3 p-3">
    <div class="row align-items-center">
      <div class="col">
        <h1 class="fs-5 fw-bold mb-0">Katalog Firm</h1>
        <p class="text-secondary mb-0">Znajdź firmę, której szukasz.</p>
      </div>
      <div class="col-auto">
        <a href="{{ path('company_add') }}" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-plus" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 5l0 14" /><path d="M5 12l14 0" /></svg>
            Dodaj firmę
        </a>
      </div>
    </div>
  </div>

  <div class="row">
    {% if promotedCompanies|length > 0 %}
    <div class="col-12 mb-4">
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">Polecane firmy</h3>
        </div>
        <div class="card-body">
          <div class="row row-cols-1 row-cols-md-3 g-3">
            {% for company in promotedCompanies %}
              <div class="col">
                <div class="card h-100 bg-light border-0">
                  <div class="card-body d-flex align-items-center p-3">
                    {% if company.logo %}
                      <img src="{{ asset(company.logo) }}" alt="{{ company.name }}" class="rounded me-3 bg-white" style="width: 64px; height: 64px; object-fit: contain;">
                    {% else %}
                      <div class="bg-white rounded d-flex align-items-center justify-content-center text-muted me-3" style="width: 64px; height: 64px;">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-building" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l18 0" /><path d="M9 8l1 0" /><path d="M9 12l1 0" /><path d="M9 16l1 0" /><path d="M14 8l1 0" /><path d="M14 12l1 0" /><path d="M14 16l1 0" /><path d="M5 21v-16a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v16" /></svg>
                      </div>
                    {% endif %}
                    <div class="overflow-hidden">
                      <h4 class="card-title mb-1 text-truncate">
                        <a href="{{ path('company_details', {slug: company.slug}) }}" class="text-decoration-none text-dark stretched-link">{{ company.name }}</a>
                      </h4>
                      <div class="text-muted small text-truncate">{{ company.city }}</div>
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    {% endif %}

    <div class="col-12 col-lg-4 col-xl-3 mb-3">
      <div class="list-group">
        <a href="{{ path('company_list') }}"
           class="list-group-item list-group-item-action d-flex align-items-center gap-2 {{ currentCategory is null ? 'active' }}">
          Wszystkie kategorie
        </a>
        {% for category in categories %}
          <a href="{{ path('company_list', {categorySlug: category.slug}) }}"
             class="list-group-item list-group-item-action {{ currentCategory and currentCategory.id == category.id ? 'active' }}">
            {{ category.name }}
          </a>
        {% endfor %}
      </div>
    </div>

    <div class="col-12 col-lg-8 col-xl-9">
      {% for company in companies %}
        <div class="card mb-3 {{ company.isPromoted ? 'border-warning shadow-sm' : '' }}" {{ company.isPromoted ? 'style="border-width: 1px;"' : '' }}>
          <div class="card-body">
            <div class="row">
                <div class="col-md-auto mb-3 mb-md-0">
                    {% if company.logo %}
                        <img src="{{ asset(company.logo) }}" alt="{{ company.name }}" class="img-fluid rounded" style="max-width: 150px; max-height: 100px;">
                    {% else %}
                         <div class="bg-light rounded d-flex align-items-center justify-content-center text-muted" style="width: 150px; height: 100px;">
                            Brak logo
                        </div>
                    {% endif %}
                </div>
                <div class="col">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h3 class="fs-5 fw-bold mb-0">
                            <a href="{{ path('company_details', {slug: company.slug}) }}" class="text-decoration-none text-dark">
                                {{ company.name }}
                            </a>
                        </h3>
                        {% if company.isPromoted %}
                            <span class="badge bg-warning text-dark">Promowana</span>
                        {% endif %}
                    </div>
                    
                    <p class="mb-2 text-muted small">
                        {{ company.address }}, {{ company.postalCode }} {{ company.city }}
                    </p>

                    <p class="mb-3">{{ company.description|striptags|slice(0, 150) }}...</p>

                    <div class="row g-2 text-muted small">
                        <div class="col-12">
                            <div class="d-flex flex-wrap gap-3">
                                {% if company.phone %}
                                    <div>
                                        <span class="fw-bold">Tel:</span> {{ company.phone }}
                                    </div>
                                {% endif %}
                                {% if company.email %}
                                    <div>
                                        <span class="fw-bold">Email:</span> {{ company.email }}
                                    </div>
                                {% endif %}
                                {% if company.website %}
                                    <div>
                                        <span class="fw-bold">WWW:</span> <a href="{{ company.website }}" target="_blank" rel="nofollow">{{ company.website|replace({'https://': '', 'http://': ''})|slice(0, 20) }}...</a>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            {% if is_granted('ROLE_ADMIN') %}
                <div class="d-flex justify-content-end align-items-center mt-3 pt-2 border-top">
                  <a href="{{ path('panel_company_edit', {'id': company.id}) }}" class="btn btn-sm btn-outline-primary me-2">
                      Edytuj
                  </a>
                  <a href="{{ path('panel_company_delete', {'id': company.id}) }}" class="btn btn-sm btn-danger text-white js-confirm" data-turbo-method="post">
                    Usuń
                  </a>
                </div>
            {% endif %}
          </div>
        </div>
      {% else %}
        <div class="card p-5 text-center text-muted">
            <p class="mb-0">Brak firm w wybranej kategorii.</p>
        </div>
      {% endfor %}

      <div class="mt-4">
        {{ paginator.toHtml|raw }}
      </div>
    </div>
  </div>
{% endblock %}
