{% extends 'app/layout/base.html.twig' %}

{% block title %}Dodaj firmę - {{ app_name }}{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <h1 class="h2 mb-4">Dodaj firmę do katalogu</h1>

            <div class="card">
                <div class="card-body">
                    <p class="mb-4">
                        Wypełnij poniższy formularz, aby dodać swoją firmę do naszego katalogu.
                        Ogłoszenie pojawi się w serwisie po akceptacji przez administratora.
                    </p>

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    {% if form_errors(form) %}
                        <div class="alert alert-danger">
                            {{ form_errors(form) }}
                        </div>
                    {% endif %}

                    <div class="mb-3">
                        {{ form_row(form.name, {'attr': {'class': 'form-control'}}) }}
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.category, {'attr': {'class': 'form-select'}}) }}
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.description, {'attr': {'class': 'form-control', 'rows': 5}}) }}
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.address, {'attr': {'class': 'form-control'}}) }}
                        </div>
                        <div class="col-md-3 mb-3">
                            {{ form_row(form.postalCode, {'attr': {'class': 'form-control'}}) }}
                        </div>
                        <div class="col-md-3 mb-3">
                            {{ form_row(form.city, {'attr': {'class': 'form-control'}}) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.phone, {'attr': {'class': 'form-control'}}) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.email, {'attr': {'class': 'form-control'}}) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.website, {'attr': {'class': 'form-control'}}) }}
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.logo, {'attr': {'class': 'form-control'}}) }}
                        <div class="form-text">Dozwolone formaty: JPG, PNG, WEBP. Maksymalny rozmiar: 2MB.</div>
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">Dodaj firmę</button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
