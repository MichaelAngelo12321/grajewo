<!doctype html>
<html lang="pl" data-bs-theme="light">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{% block description %}{{ app_meta_description }}{% endblock %}">
  <meta name="robots" content="{% block robots %}index, follow{% endblock %}">
  <link rel="canonical" href="{% block canonical %}{{ app.request.schemeAndHttpHost ~ app.request.requestUri }}{% endblock %}">
  <title>{% block title %}{% endblock %}</title>

  <meta property="og:type" content="{% block og_type %}website{% endblock %}">
  <meta property="og:url" content="{% block og_url %}{{ app.request.schemeAndHttpHost ~ app.request.requestUri }}{% endblock %}">
  <meta property="og:title" content="{% block og_title %}{{ block('title') }}{% endblock %}">
  <meta property="og:description" content="{% block og_description %}{{ block('description') }}{% endblock %}">
  <meta property="og:image" content="{% block og_image %}{{ app.request.schemeAndHttpHost ~ asset('build/images/default-share-image.jpg') }}{% endblock %}">

  <meta name="twitter:card" content="{% block twitter_card %}summary_large_image{% endblock %}">
  <meta name="twitter:title" content="{% block twitter_title %}{{ block('title') }}{% endblock %}">
  <meta name="twitter:description" content="{% block twitter_description %}{{ block('description') }}{% endblock %}">
  <meta name="twitter:image" content="{% block twitter_image %}{{ app.request.schemeAndHttpHost ~ asset('build/images/default-share-image.jpg') }}{% endblock %}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fira+Sans:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="shortcut icon" type="image/png" href="{{ asset('build/images/favicon.png') }}"/>

  {{ encore_entry_script_tags('app') }}
  {{ encore_entry_link_tags('app') }}

  {% block stylesheets %}
  {% endblock %}

  {% block javascripts %}
  {% endblock %}

  {% block structured_data %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ app_name }}",
    "url": "{{ app.request.schemeAndHttpHost }}"
  }
  </script>
  {% endblock %}
</head>
<body>
{% include 'app/layout/_header.html.twig' %}

<div class="container container-main">
  {% include 'app/widgets/promo_space.html.twig' with {
    'slot': 'TOP_1'
  } %}

  {% block topContent %}{% endblock %}

  <div class="row">
    <main class="col">
      {% block body %}{% endblock %}

      {% include 'app/widgets/promo_space.html.twig' with {
        'slot': 'STOPKA_1'
      } %}
    </main>

    <aside class="col-md-4 col-lg-3">
      {% block sidebar %}{% endblock %}
      {% include 'app/layout/_sidebar.html.twig' %}
    </aside>
  </div>
</div>

{% include 'app/layout/_bottom.html.twig' %}

{% include 'app/widgets/popup.html.twig' %}

{% include 'app/layout/_footer.html.twig' %}
</body>
</html>

{{ update_promo_item_view_counters() }}
