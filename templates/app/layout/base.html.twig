<!doctype html>
<html lang="pl" data-bs-theme="light">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{% block description %}{{ app_meta_description }}{% endblock %}">
  <title>{% block title %}{% endblock %}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="shortcut icon" type="image/png" href="{{ asset('build/images/favicon.png') }}"/>

  {{ encore_entry_script_tags('app') }}
  {{ encore_entry_link_tags('app') }}

  {% block stylesheets %}
  {% endblock %}

  {% block javascripts %}
  {% endblock %}
</head>
<body>
{% include 'app/layout/_header.html.twig' %}

<div class="container container-main">
  {% block topContent %}{% endblock %}

  <div class="row">
    <main class="col">
      {% block body %}{% endblock %}
    </main>

    <aside class="col-md-4 col-lg-3">
      {% block sidebar %}{% endblock %}
      {% include 'app/layout/_sidebar.html.twig' %}
    </aside>
  </div>
</div>

{% include 'app/layout/_bottom.html.twig' %}

{% include 'app/layout/_footer.html.twig' %}
</body>
</html>
