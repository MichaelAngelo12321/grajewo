{% extends 'app/layout/base.html.twig' %}

{% block title %}Dodaj ogłoszenie - {{ app_name }}{% endblock %}

{% block topContent %}
  <nav class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="{{ path('homepage') }}">Strona główna</a></li>
      <li class="breadcrumb-item"><a href="{{ path('advertisement_list') }}">Ogłoszenia</a></li>
      <li class="breadcrumb-item active">Dodaj ogłoszenie</li>
    </ol>
  </nav>
{% endblock %}

{% block body %}
  <h1 class="fs-5 fw-bold mb-4">Dodaj ogłoszenie</h1>

  {{ form_start(form) }}

  {% for type, messages in app.flashes() %}
    {% for message in messages %}
      <div class="alert alert-{{ type }}">
        {{ message }}
      </div>
    {% endfor %}
  {% endfor %}

  {{ form_widget(form) }}
  <button type="submit" class="btn btn-primary">Dodaj ogłoszenie</button>
  {{ form_end(form) }}

  <div class="fs-smaller text-muted mt-2">
    Formularz chroniony przez reCAPTCHA i Google (<a class="text-muted" href="https://policies.google.com/privacy">Polityka prywatności</a>)
  </div>

  <hr class="d-block d-md-none my-5" />
{% endblock %}
