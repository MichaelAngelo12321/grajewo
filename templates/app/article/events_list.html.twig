{% extends 'app/layout/base.html.twig' %}

{% block title %}Kalendarz wydarzeń - {{ app_name }}{% endblock %}
{% block description %}Kalendarz imprez, wydarzeń z miasta i okolic w serwisie regionalnym {{ app_name }}.{% endblock %}

{% block topContent %}
  <nav class="mb-2 border-left border-danger-subtle border-2">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="{{ path('homepage') }}">Strona główna</a></li>
      <li class="breadcrumb-item active">Kalendarz wydarzeń</li>
    </ol>
  </nav>
{% endblock %}

{% block body %}
  <div class="widget mt-1">
    <h1 class="section-title primary">Lista nadchodzących wydarzeń</h1>

    <div class="row">
      {% for event in events %}
        {% include 'app/article/_event-item.html.twig' %}
      {% endfor %}
    </div>
  </div>
{% endblock %}
